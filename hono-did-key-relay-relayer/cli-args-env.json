{
  "name": "hono-did-key-relay-relayer",
  "description": "XRPC relay server",
  "options": [
    {
      "name": "hostname",
      "type": "string",
      "description": "Server hostname for DID doc and proxy refs",
      "env": "HOSTNAME",
      "default": "xrpc.fedproxy.com"
    },
    {
      "name": "service-id",
      "type": "string",
      "description": "Service ID in the DID document",
      "env": "SERVICE_ID",
      "default": "xrpc_relay"
    },
    {
      "name": "port",
      "type": "number",
      "description": "TCP port to listen on",
      "env": "PORT",
      "default": 8080
    },
    {
      "name": "unix-socket",
      "type": "string",
      "description": "Unix socket path (takes precedence over --port)",
      "env": "UNIX_SOCKET",
      "default": ""
    },
    {
      "name": "relay-timeout-ms",
      "type": "number",
      "description": "Timeout for relay operations",
      "env": "RELAY_TIMEOUT_MS",
      "default": 30000
    },
    {
      "name": "reconnect-grace-ms",
      "type": "number",
      "description": "Grace period for reconnect",
      "env": "RECONNECT_GRACE_MS",
      "default": 10000
    },
    {
      "name": "nonce-ttl-ms",
      "type": "number",
      "description": "TTL for nonces",
      "env": "NONCE_TTL_MS",
      "default": 60000
    }
  ]
}
